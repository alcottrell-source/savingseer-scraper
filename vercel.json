{
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/:path((?!admin\\.html|.*\\.(?:js|css|svg|png|jpg|jpeg|webp|woff2?|ico|map|json|txt)).*)", "has": [{ "type": "host", "value": "admin.tidego.co" }], "destination": "/admin.html" },
    { "source": "/", "has": [{ "type": "host", "value": "admin.tidego.co" }], "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(index.html)?",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
