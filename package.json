{
  "name": "tide-scraper",
  "version": "2.0.0",
  "description": "Tide — daily brand scraper and Tide scorer",
  "type": "module",
  "scripts": {
    "scrape": "node scraper.js",
    "score": "node score.js",
    "summarise": "node summarise.js",
    "run-all": "node scraper.js && node score.js && node summarise.js",
    "test": "playwright test",
    "test:desktop": "playwright test --project=desktop-chromium",
    "test:mobile": "playwright test --project=mobile-chromium",
    "test:headed": "playwright test --headed"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@supabase/supabase-js": "^2.39.0",
    "crawlee": "^3.9.0",
    "playwright": "^1.42.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
