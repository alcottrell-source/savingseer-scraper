{
  "name": "tide-scraper",
  "version": "2.0.0",
  "description": "Tide — daily brand scraper and Tide scorer",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "scrape": "node scraper.js",
    "score": "node score.js",
    "summarise": "node summarise.js",
    "run-all": "node scraper.js && node score.js && node summarise.js",
    "test": "node --test test/*.test.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@supabase/supabase-js": "^2.39.0",
    "crawlee": "^3.9.0",
    "playwright": "^1.42.0"
  }
}
